{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ome Music",
  "version": "0.1.0",
  "identifier": "com.ome.music",
  "build": {
    "beforeDevCommand": "npm.cmd run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm.cmd run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ome Music",
        "width": 1280,
        "height": 820,
        "minWidth": 1040,
        "minHeight": 720,
        "theme": "Dark",
        "transparent": true,
        "decorations": false,
        "shadow": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/com.ome.music/**",
          "$LOCALAPPDATA/com.ome.music/**",
          "$HOME/Music/**",
          "$HOME/Downloads/**",
          "$DOWNLOAD/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": false
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    }
  }
}
