# Ome Music does not require environment variables for normal use.
# Configure providers and music sources in the app settings.
#
# Never commit real API keys, cookies, tokens, passwords, or local account data.

# Optional local development examples only:
# OME_MUSIC_PROVIDER_BASE_URL=https://provider.example/v1
# OME_MUSIC_PROVIDER_MODEL=example-model
# OME_MUSIC_PROVIDER_API_KEY=
